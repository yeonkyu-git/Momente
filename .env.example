# ─── Supabase ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=                # Supabase 프로젝트 URL
EXPO_PUBLIC_SUPABASE_ANON_KEY=           # Supabase anon key (공개 가능)
SUPABASE_SERVICE_ROLE_KEY=               # Supabase service role (백엔드 전용, 절대 노출 금지)

# ─── 카카오 ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_KAKAO_APP_KEY=               # 카카오 앱 키 (네이티브)
KAKAO_CLIENT_SECRET=                     # 카카오 클라이언트 시크릿 (백엔드 전용)

# ─── 네이버 ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=         # 네이버 지도 클라이언트 ID (지도 렌더링, 공개 가능)
NAVER_MAP_CLIENT_SECRET=                 # 네이버 지도 시크릿 (백엔드 전용)
NAVER_SEARCH_CLIENT_ID=                  # 네이버 검색 API 클라이언트 ID (백엔드 전용)
NAVER_SEARCH_CLIENT_SECRET=              # 네이버 검색 시크릿 (백엔드 전용)

# ─── 백엔드 서버 ─────────────────────────────────────────────────────────────
JWT_SECRET=                              # JWT 서명 키 (절대 노출 금지, 32자 이상 랜덤 문자열)
PORT=3000
EXPO_PUBLIC_API_BASE_URL=                # Express 서버 URL (예: https://your-app.onrender.com)
